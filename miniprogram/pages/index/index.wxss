.page { padding: 32rpx; }
.header { margin: 24rpx 0 40rpx; }
.title { display: block; font-size: 48rpx; font-weight: 600; color: #222; }
.subtitle { display: block; margin-top: 8rpx; font-size: 28rpx; color: #888; }
.module-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-title { display: block; font-size: 34rpx; font-weight: 600; color: #222; }
.card-desc { display: block; margin-top: 8rpx; font-size: 26rpx; color: #999; }
