<view class="page">
  <view class="filters">
    <picker class="f-item" mode="selector" range="{{subjectLabels}}" value="{{subjectIndex}}" bindchange="onSubjectPick">
      <view class="f-pick">{{subjectLabels[subjectIndex]}} ▾</view>
    </picker>
    <picker class="f-item" mode="selector" range="{{hospitalLabels}}" value="{{hospitalIndex}}" bindchange="onHospitalPick">
      <view class="f-pick">{{hospitalLabels[hospitalIndex]}} ▾</view>
    </picker>
    <picker class="f-item" mode="selector" range="{{timeRanges}}" value="{{timeIndex}}" bindchange="onTimePick">
      <view class="f-pick">{{timeRanges[timeIndex]}} ▾</view>
    </picker>
  </view>

  <view wx:if="{{showCustom}}" class="custom-range">
    <picker mode="date" value="{{customFrom}}" bindchange="onCustomFrom">
      <view class="date-pick">{{customFrom || '起始日期'}}</view>
    </picker>
    <text class="date-sep">至</text>
    <picker mode="date" value="{{customTo}}" bindchange="onCustomTo">
      <view class="date-pick">{{customTo || '结束日期'}}</view>
    </picker>
  </view>

  <view wx:if="{{items.length === 0}}" class="empty">暂无检查记录</view>
  <view wx:for="{{items}}" wx:key="id" class="item" bindtap="goDetail" data-id="{{item.id}}">
    <view class="row">
      <text class="type">{{item.report_type_label || item.report_type}}</text>
      <text class="date">{{item.report_date || '日期未知'}}</text>
    </view>
    <view class="row sub">
      <text class="uploader">{{item.subject_nickname || '未指定'}} · 医院：{{item.hospital || '—'}}</text>
      <text wx:if="{{item.abnormal_count > 0}}" class="abnormal">{{item.abnormal_count}} 项异常</text>
      <text wx:elif="{{item.status === 'failed'}}" class="failed">识别失败</text>
      <text wx:else class="normal">正常</text>
    </view>
    <view class="del" catchtap="onDelete" data-id="{{item.id}}">删除</view>
  </view>
</view>
