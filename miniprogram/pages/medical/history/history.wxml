<view class="page">
  <view class="hero">
    <text class="hero-title">检查历史</text>
    <text class="hero-subtitle">先选择成员，再筛选时间和医院</text>
  </view>

  <view class="filter-stack">
    <view class="select-card">
      <picker class="picker-wrap" mode="selector" range="{{subjectLabels}}" value="{{subjectIndex}}" bindchange="onSubjectPick">
        <view class="picker-row single-line-row">
          <text class="picker-label">成员</text>
          <text class="picker-value">{{memberDisplay}} ▾</text>
        </view>
      </picker>
    </view>

    <view class="select-card">
      <picker class="picker-wrap" mode="selector" range="{{timeRanges}}" value="{{timeIndex}}" bindchange="onTimePick">
        <view class="picker-row single-line-row">
          <text class="picker-label">时间范围</text>
          <text class="picker-value">{{timeDisplay}} ▾</text>
        </view>
      </picker>
      <view wx:if="{{showCustom}}" class="custom-inline">
        <picker mode="date" value="{{customFrom}}" bindchange="onCustomFrom">
          <view class="picker-row single-line-row">
            <text class="picker-label">起始日期</text>
            <text class="picker-value">{{customFrom || '请选择'}} ▾</text>
          </view>
        </picker>
        <picker mode="date" value="{{customTo}}" bindchange="onCustomTo">
          <view class="picker-row single-line-row">
            <text class="picker-label">结束日期</text>
            <text class="picker-value">{{customTo || '请选择'}} ▾</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="select-card">
      <view class="picker-row single-line-row" bindtap="toggleHospitalPanel">
        <text class="picker-label">医院</text>
        <text class="picker-value">{{hospitalDisplay}} ▾</text>
      </view>
      <view wx:if="{{hospitalPanelOpen}}" class="hospital-options">
        <view class="hospital-actions">
          <text class="hospital-count">共 {{hospitals.length}} 家</text>
          <text class="section-action" bindtap="clearHospitals">清空</text>
        </view>
        <view wx:if="{{hospitals.length === 0}}" class="hospital-empty">当前筛选结果没有医院可选</view>
        <view wx:for="{{hospitalOptions}}" wx:key="name" class="hospital-chip {{item.selected ? 'active' : ''}}" data-hospital="{{item.name}}" bindtap="onHospitalToggle">
          <text>{{item.name}}</text>
          <text wx:if="{{item.selected}}" class="hospital-check">✓</text>
        </view>
      </view>
    </view>
  </view>


  <view wx:if="{{items.length === 0}}" class="empty">暂无检查记录</view>
  <view wx:for="{{items}}" wx:key="id" class="item" bindtap="goDetail" data-id="{{item.id}}">
    <view class="row">
      <text class="type">{{item.report_type_label || item.report_type}}</text>
      <text class="date">{{item.report_date || '日期未知'}}</text>
    </view>
    <view class="row sub">
      <text class="uploader">{{item.subject_nickname || '未指定'}} · 医院：{{item.hospital || '—'}}</text>
      <text wx:if="{{item.abnormal_count > 0}}" class="abnormal">{{item.abnormal_count}} 项异常</text>
      <text wx:elif="{{item.status === 'failed'}}" class="failed">识别失败</text>
      <text wx:else class="normal">正常</text>
    </view>
    <view class="del" catchtap="onDelete" data-id="{{item.id}}">删除</view>
  </view>
</view>