.page { padding: 24rpx 32rpx; }
.filters { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.f-item { flex: 1; min-width: 0; }
.f-pick { background: #fff; border-radius: 8rpx; padding: 14rpx 12rpx; font-size: 24rpx; color: #07c160; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hospital-panel { background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.panel-title { font-size: 26rpx; font-weight: 600; color: #222; }
.panel-clear { font-size: 24rpx; color: #07c160; }
.hospital-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.hospital-chip { padding: 10rpx 20rpx; border-radius: 999rpx; background: #f5f5f5; font-size: 24rpx; color: #666; }
.hospital-chip.active { background: #e8f8ef; color: #07c160; }
.custom-range { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.date-pick { background: #fff; border-radius: 8rpx; padding: 14rpx 20rpx; font-size: 24rpx; color: #333; }
.date-sep { font-size: 24rpx; color: #888; }
.empty { text-align: center; color: #999; margin-top: 120rpx; font-size: 28rpx; }
.item { position: relative; background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.row { display: flex; justify-content: space-between; align-items: center; }
.row.sub { margin-top: 12rpx; }
.type { font-size: 32rpx; font-weight: 600; color: #222; }
.date { font-size: 26rpx; color: #888; }
.uploader { font-size: 24rpx; color: #999; }
.abnormal { font-size: 24rpx; color: #e64340; }
.failed { font-size: 24rpx; color: #fa8c16; }
.normal { font-size: 24rpx; color: #07c160; }
.del { margin-top: 20rpx; text-align: center; font-size: 26rpx; color: #e64340; border-top: 1rpx solid #f0f0f0; padding-top: 18rpx; }
