.page { padding: 24rpx 28rpx 160rpx; background: #f6f7f9; }
.hero { margin-bottom: 20rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #222; }
.hero-subtitle { display: block; margin-top: 8rpx; font-size: 24rpx; color: #888; }
.filter-stack { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 20rpx; }
.select-card { background: #fff; border-radius: 18rpx; padding: 16rpx 20rpx; box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.04); }
.section-action { font-size: 24rpx; color: #07c160; }
.picker-row { background: #f7f7f7; border-radius: 12rpx; padding: 18rpx; display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.single-line-row { padding-top: 14rpx; padding-bottom: 14rpx; }
.picker-label { flex-shrink: 0; font-size: 26rpx; color: #666; }
.picker-value { flex: 1; min-width: 0; font-size: 26rpx; color: #07c160; text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hospital-options { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 12rpx; }
.hospital-actions { width: 100%; display: flex; align-items: center; justify-content: space-between; margin-bottom: 4rpx; }
.hospital-count { font-size: 22rpx; color: #999; }
.hospital-empty { width: 100%; font-size: 22rpx; color: #999; margin: 4rpx 0 8rpx; }
.hospital-chip { padding: 10rpx 20rpx; border-radius: 999rpx; background: #f5f5f5; border: 1rpx solid #e5e5e5; font-size: 24rpx; color: #666; display: inline-flex; align-items: center; gap: 8rpx; }
.hospital-chip.active { background: #07c160; border-color: #07c160; color: #fff; font-weight: 600; }
.hospital-check { font-size: 22rpx; line-height: 1; }
.custom-inline { display: flex; flex-direction: column; gap: 10rpx; margin-top: 10rpx; }
.empty { text-align: center; color: #999; margin-top: 120rpx; font-size: 28rpx; }
.item { position: relative; background: #fff; border-radius: 18rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.04); }
.row { display: flex; justify-content: space-between; align-items: center; }
.row.sub { margin-top: 12rpx; }
.type { font-size: 32rpx; font-weight: 600; color: #222; }
.date { font-size: 26rpx; color: #888; }
.uploader { font-size: 24rpx; color: #999; }
.abnormal { font-size: 24rpx; color: #e64340; }
.failed { font-size: 24rpx; color: #fa8c16; }
.normal { font-size: 24rpx; color: #07c160; }
.del { margin-top: 20rpx; text-align: center; font-size: 26rpx; color: #e64340; border-top: 1rpx solid #f0f0f0; padding-top: 18rpx; }
@media (max-width: 360px) { .filter-stack { gap: 12rpx; } }