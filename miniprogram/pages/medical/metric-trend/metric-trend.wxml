<view class="page">
  <view class="picker-bar">
    <picker mode="selector" range="{{catalogLabels}}" value="{{selectedIndex}}" bindchange="onPick">
      <view class="picker">
        {{catalog.length ? catalog[selectedIndex].item_name : '选择指标'}}
        <text class="arrow">▾</text>
      </view>
    </picker>
  </view>

  <view wx:if="{{trend}}" class="chart-card">
    <text class="chart-title">{{trend.item_name}} {{trend.unit ? '(' + trend.unit + ')' : ''}}</text>
    <canvas type="2d" id="trendCanvas" class="chart"></canvas>
    <view class="legend">
      <text class="legend-band">浅绿区间 = 参考范围</text>
      <text class="legend-dot">点颜色 = 医院来源（见下方列表）</text>
    </view>
    <view wx:if="{{trend.points && trend.points.length}}" class="legend-list">
      <view wx:for="{{trend.points}}" wx:key="report_id" class="legend-row">
        <text>{{item.report_date || '日期未知'}}：{{item.hospital || '医院未知'}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{catalog.length === 0}}" class="empty">暂无可展示的指标，请先上传检查单</view>
</view>
