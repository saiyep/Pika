.page { padding: 24rpx 32rpx; }
.picker-bar { margin-bottom: 24rpx; }
.picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.arrow { color: #999; }
.chart-card { background: #fff; border-radius: 12rpx; padding: 24rpx; }
.chart-title { display: block; font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; color: #222; }
.chart { width: 100%; height: 400rpx; }
.legend { margin-top: 16rpx; display: flex; gap: 32rpx; }
.legend-band, .legend-dot { font-size: 22rpx; color: #999; }
.legend-list { margin-top: 12rpx; }
.legend-row { font-size: 22rpx; color: #666; line-height: 1.6; }
.empty { text-align: center; color: #999; margin-top: 120rpx; font-size: 28rpx; }
