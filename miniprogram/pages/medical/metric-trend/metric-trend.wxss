.page { padding: 24rpx 28rpx 160rpx; background: #f6f7f9; min-height: 100vh; box-sizing: border-box; }
.hero { margin-bottom: 20rpx; }
.hero-title { display: block; font-size: 36rpx; font-weight: 600; color: #222; }
.hero-subtitle { display: block; margin-top: 8rpx; font-size: 24rpx; color: #888; }
.filter-stack { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 20rpx; }
.select-card, .content-card, .state-card { background: #fff; border-radius: 18rpx; padding: 24rpx; box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04); }
.select-card { padding: 16rpx 20rpx; }
.state-card { text-align: center; color: #999; font-size: 28rpx; padding: 48rpx 24rpx; margin-bottom: 20rpx; }
.state-inline { background: #f7f7f7; border-radius: 12rpx; padding: 24rpx 18rpx; font-size: 24rpx; color: #999; }
.picker-row { background: #f7f7f7; border-radius: 12rpx; padding: 18rpx; display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.single-line-row { padding-top: 14rpx; padding-bottom: 14rpx; }
.picker-label { flex-shrink: 0; font-size: 26rpx; color: #666; }
.picker-value { font-size: 26rpx; color: #07c160; text-align: right; flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.custom-inline { display: flex; flex-direction: column; gap: 10rpx; margin-top: 10rpx; }
.content-title { display: block; font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; color: #222; }
.view-switch { display: inline-flex; margin-bottom: 20rpx; padding: 6rpx; background: #f5f5f5; border-radius: 999rpx; }
.switch-item { min-width: 132rpx; padding: 12rpx 24rpx; text-align: center; font-size: 24rpx; color: #666; border-radius: 999rpx; }
.switch-item.active { background: #07c160; color: #fff; }
.metrics { border-radius: 12rpx; border: 1rpx solid #f0f0f0; overflow: hidden; }
.m-head, .m-row { display: grid; grid-template-columns: 1.4fr 1.5fr 1.2fr 1.4fr; gap: 12rpx; padding: 20rpx 16rpx; font-size: 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.m-head { background: #fafafa; color: #999; }
.m-row { color: #333; }
.m-row:last-child { border-bottom: none; }
.c-date, .c-hospital { color: #666; }
.c-value, .c-ref { text-align: right; }
.m-row.abnormal .c-value { color: #e64340; font-weight: 600; }
.chart-wrap { position: relative; margin-top: 8rpx; }
.chart { width: 100%; height: 440rpx; }
.chart-tooltip { position: absolute; min-width: 180rpx; max-width: 320rpx; padding: 14rpx 18rpx; border-radius: 12rpx; background: rgba(34, 34, 34, 0.92); color: #fff; transform: translate(-50%, calc(-100% - 12px)); box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.18); pointer-events: none; z-index: 2; }
.tooltip-date { display: block; font-size: 22rpx; opacity: 0.88; }
.tooltip-value { display: block; margin-top: 4rpx; font-size: 26rpx; font-weight: 600; }
.tooltip-meta { display: block; margin-top: 4rpx; font-size: 22rpx; opacity: 0.9; }
.legend { margin-top: 16rpx; display: flex; flex-wrap: wrap; gap: 24rpx; }
.legend-band, .legend-dot { font-size: 22rpx; color: #999; }
.chart-note { margin-top: 12rpx; font-size: 22rpx; color: #fa8c16; }
.empty-inline { text-align: center; color: #999; padding: 80rpx 0 56rpx; font-size: 26rpx; }
@media (max-width: 360px) { .filter-stack { gap: 12rpx; } }
