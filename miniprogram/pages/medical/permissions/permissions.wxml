<view class="page">
  <view class="tip">你可以设置家庭成员对“我的就医数据”的权限。</view>

  <view wx:if="{{loading}}" class="loading">加载中…</view>
  <view wx:elif="{{members.length === 0}}" class="empty">暂无可授权成员</view>

  <view wx:for="{{members}}" wx:key="id" class="card">
    <view class="member-head">
      <text class="name">{{item.nickname || ('用户' + item.id)}}</text>
      <text class="role">{{item.family_role === 'admin' ? '管理员' : '普通成员'}}</text>
    </view>

    <view class="action-row" wx:for="{{item.actionItems}}" wx:key="key">
      <text class="label">{{item.label}}</text>
      <switch
        checked="{{item.checked}}"
        data-member-id="{{item.id}}"
        data-action="{{item.key}}"
        bindchange="onToggleAction"
        color="#07c160"
      />
    </view>

    <button class="save-btn" size="mini" data-member-id="{{item.id}}" bindtap="onSaveMember" loading="{{saving}}" disabled="{{saving}}">保存该成员权限</button>
  </view>
</view>
