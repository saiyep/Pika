.page { padding: 24rpx 28rpx 160rpx; background: #f6f7f9; }
.hero { margin-bottom: 20rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #222; }
.state-card { margin-top: 100rpx; text-align: center; color: #999; font-size: 28rpx; background: #fff; border-radius: 18rpx; padding: 48rpx 24rpx; }
.member-card, .permissions-card { background: #fff; border-radius: 18rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.04); }
.member-card-clickable { padding: 22rpx 24rpx; }
.section-title { font-size: 24rpx; color: #666; margin-bottom: 14rpx; }
.member-head { display: flex; align-items: center; }
.member-avatar { width: 88rpx; height: 88rpx; border-radius: 44rpx; background: #07c160; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 36rpx; font-weight: 600; margin-right: 18rpx; }
.member-meta { flex: 1; }
.member-name { font-size: 32rpx; font-weight: 600; color: #222; }
.picker-arrow { font-size: 30rpx; color: #999; }
.permission-row { display: flex; align-items: center; justify-content: space-between; padding: 18rpx 0; border-bottom: 1rpx solid #f2f2f2; }
.permission-row:last-of-type { border-bottom: none; }
.permission-copy { flex: 1; padding-right: 24rpx; }
.permission-label { font-size: 28rpx; color: #222; margin-bottom: 6rpx; }
.permission-desc { font-size: 22rpx; color: #999; line-height: 1.5; }
.bottom-bar { position: fixed; left: 24rpx; right: 24rpx; bottom: 24rpx; display: flex; gap: 16rpx; background: rgba(246,247,249,0.96); padding-top: 12rpx; }
.act { flex: 1; border-radius: 14rpx; font-size: 28rpx; }
.act.ghost { background: #fff; color: #333; }
.act.primary { background: #07c160; color: #fff; }
