.page { padding: 32rpx; }
.empty { color: #999; font-size: 26rpx; margin: 10rpx 0 20rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #222; }
.add-btn { min-width: 112rpx; }
.item { background: #fff; border-radius: 14rpx; padding: 22rpx 24rpx; margin-bottom: 16rpx; display: flex; align-items: center; }
.item-main { flex: 1; min-width: 0; }
.name { display: block; font-size: 30rpx; color: #222; line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.icon-actions { margin-left: 16rpx; display: flex; align-items: center; justify-content: flex-end; gap: 12rpx; }
.icon-btn { width: 52rpx; height: 52rpx; border-radius: 26rpx; display: flex; align-items: center; justify-content: center; background: #f1f3f5; color: #555; font-size: 28rpx; line-height: 1; }
.icon-btn.del { color: #d9534f; }
