.page { padding: 24rpx 32rpx; }
.image-wrap { border-radius: 12rpx; overflow: hidden; margin-bottom: 24rpx; }
.image-wrap image { width: 100%; }
.info { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16rpx; }
.type { font-size: 36rpx; font-weight: 600; color: #222; }
.date { font-size: 26rpx; color: #888; }
.failed-tip { display: flex; justify-content: space-between; align-items: center; background: #fff7e6; color: #fa8c16; font-size: 26rpx; padding: 16rpx; border-radius: 8rpx; margin-bottom: 16rpx; }
.reparse-btn { margin: 0; color: #fa8c16; background: #fff; border: 1rpx solid #fa8c16; }
.metrics { background: #fff; border-radius: 12rpx; padding: 8rpx 24rpx; }
.m-head, .m-row { display: flex; padding: 18rpx 0; font-size: 26rpx; border-bottom: 1rpx solid #f0f0f0; }
.m-head { color: #999; font-size: 24rpx; }
.c-name { flex: 2; color: #333; }
.c-value { flex: 1.5; text-align: right; color: #333; }
.c-ref { flex: 2; text-align: right; color: #999; }
.m-row.abnormal .c-value { color: #e64340; font-weight: 600; }
