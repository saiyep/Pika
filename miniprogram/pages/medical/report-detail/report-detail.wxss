.page { padding: 24rpx 32rpx; }
.info-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 16rpx; margin-bottom: 16rpx; }
.info-main { flex: 1; min-width: 0; }
.type { display: block; font-size: 36rpx; font-weight: 600; color: #222; line-height: 1.3; }
.meta { background: #fff; border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.meta-line { display: block; font-size: 26rpx; color: #666; line-height: 1.9; }
.failed-tip { display: flex; justify-content: space-between; align-items: center; background: #fff7e6; color: #fa8c16; font-size: 26rpx; padding: 16rpx; border-radius: 8rpx; margin-bottom: 16rpx; }
.reparse-btn { margin: 0; color: #fa8c16; background: #fff; border: 1rpx solid #fa8c16; }
.metrics { background: #fff; border-radius: 12rpx; padding: 8rpx 24rpx; }
.m-head, .m-row { display: flex; padding: 18rpx 0; font-size: 26rpx; border-bottom: 1rpx solid #f0f0f0; }
.m-head { color: #999; font-size: 24rpx; }
.c-name { flex: 2; color: #333; }
.c-value { flex: 1.5; text-align: right; color: #333; }
.c-ref { flex: 2; text-align: right; color: #999; }
.m-row.abnormal .c-value { color: #e64340; font-weight: 600; }
.toolbar { display: flex; justify-content: flex-end; gap: 16rpx; margin-bottom: 16rpx; }
.tool-btn { padding: 8rpx 24rpx; font-size: 24rpx; line-height: 1.5; border-radius: 999rpx; background: #fff; color: #07c160; border: 1rpx solid #07c160; flex: none; }
.tool-btn.primary { background: #07c160; color: #fff; }
.tool-btn.ghost { color: #888; border-color: #ccc; }
.tool-btn.disabled { opacity: 0.5; }
.image-entry { margin-top: 20rpx; display: flex; justify-content: flex-start; }
.image-link { padding: 14rpx 24rpx; border-radius: 999rpx; background: #eefaf4; color: #07c160; font-size: 24rpx; }
.image-link.disabled { opacity: 0.7; }
.edit-section { margin-bottom: 20rpx; }
.field-label { display: block; font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.field-input { background: #fff; border-radius: 12rpx; padding: 18rpx; font-size: 26rpx; }
.picker { background: #fff; border-radius: 12rpx; padding: 18rpx; font-size: 26rpx; color: #333; }
.picker + .field-input { margin-top: 12rpx; }
.edit-metric { display: grid; grid-template-columns: 2fr 1.2fr 1fr 1.5fr; gap: 8rpx; padding: 8rpx 0; }
.edit-metric input { background: #fff; border-radius: 8rpx; padding: 12rpx; font-size: 22rpx; }
