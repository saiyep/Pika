<view class="page">
  <view class="card" bindtap="goPermissions">
    <text class="title">成员权限设置</text>
    <text class="desc">管理家庭成员对我就医数据的访问权限</text>
  </view>

  <view class="card" bindtap="goFocusMetrics">
    <text class="title">我的关注指标</text>
    <text class="desc">按检查类别管理个人关注项</text>
  </view>

  <view class="card" bindtap="goReportCategories">
    <text class="title">我的检查单分类</text>
    <text class="desc">管理检查单分类名称与启用状态</text>
  </view>
</view>
