.page { padding: 32rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; }
.title { display: block; font-size: 30rpx; font-weight: 600; color: #222; }
.desc { display: block; margin-top: 10rpx; font-size: 24rpx; color: #888; }
.row { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.name { display: block; font-size: 28rpx; color: #333; }
.meta { display: block; margin-top: 6rpx; font-size: 22rpx; color: #999; }
