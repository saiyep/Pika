<view class="page">
  <view class="section">
    <text class="section-title">医院</text>
    <picker mode="selector" range="{{hospitalOptions}}" value="{{hospitalIndex}}" bindchange="onHospitalPick">
      <view class="picker">{{hospitalOptions[hospitalIndex]}}</view>
    </picker>
    <input wx:if="{{hospitalIndex === hospitalOptions.length - 1}}" class="input" placeholder="请输入医院名称" value="{{hospitalCustom}}" bindinput="onHospitalCustomInput" />
  </view>

  <view wx:if="{{step === 'pick'}}">
    <view class="preview-list" wx:if="{{files.length}}">
      <view class="preview-item" wx:for="{{files}}" wx:key="id">
        <image src="{{item.path}}" mode="aspectFill" />
        <text class="remove" data-id="{{item.id}}" bindtap="removeImage">✕</text>
      </view>
    </view>

    <button class="btn" bindtap="chooseImage">{{files.length ? '重新选择（可多张）' : '拍照 / 选择检查单（可多张）'}}</button>
    <button wx:if="{{files.length}}" class="btn primary" bindtap="createDraft" loading="{{uploading}}" disabled="{{uploading}}">
      {{uploading ? '识别中…' : '开始识别并编辑'}}
    </button>
  </view>

  <view wx:if="{{step === 'edit'}}" class="result">
    <text class="result-title">识别结果（可手动修正后提交）</text>
    <view class="section mini">
      <text class="section-title">报告类型标签</text>
      <input class="input" placeholder="如：血常规" value="{{reportTypeLabel}}" bindinput="onReportTypeInput" />
    </view>

    <view wx:for="{{metrics}}" wx:key="seq" class="metric">
      <input class="m-name" data-idx="{{index}}" data-field="item_name" value="{{item.item_name}}" bindinput="onMetricFieldInput" />
      <input class="m-value" data-idx="{{index}}" data-field="value_text" value="{{item.value_text}}" bindinput="onMetricFieldInput" />
      <input class="m-unit" data-idx="{{index}}" data-field="unit" value="{{item.unit}}" bindinput="onMetricFieldInput" />
      <input class="m-ref" data-idx="{{index}}" data-field="ref_range" value="{{item.ref_range}}" bindinput="onMetricFieldInput" />
    </view>

    <button class="btn primary" bindtap="submitDraft">确认无误并提交</button>
  </view>
</view>
