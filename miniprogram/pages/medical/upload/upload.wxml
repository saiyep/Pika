<view class="page">
  <view class="hero">
    <view class="hero-title">上传检查单</view>
    <view class="hero-subtitle">可拍照或从相册导入，支持同一次上传多张同类检查单。</view>
  </view>

  <block wx:if="{{step === 'pick'}}">
    <view class="select-card">
      <picker mode="selector" range="{{memberLabels}}" value="{{subjectIndex}}" bindchange="onSubjectPick">
        <view class="picker-row">
          <text class="picker-label">检查成员</text>
          <text class="picker-value">{{memberLabels[subjectIndex] || '（未登录成员）'}} ▾</text>
        </view>
      </picker>
    </view>

    <view class="select-card">
      <text class="section-title">检查单图片</text>
      <view wx:if="{{!files.length}}" class="upload-dropzone" bindtap="chooseImage">
        <view class="upload-icon">＋</view>
        <view class="upload-title">添加检查单</view>
        <view class="upload-subtitle">支持拍照或从相册导入，可多张</view>
      </view>
      <block wx:else>
        <view class="preview-list">
          <view class="preview-item" wx:for="{{files}}" wx:key="id">
            <image src="{{item.path}}" mode="aspectFill" />
            <text class="remove" data-id="{{item.id}}" bindtap="removeImage">✕</text>
          </view>
        </view>
        <button class="btn choose-btn" bindtap="chooseImage">继续添加</button>
      </block>
    </view>

    <view wx:if="{{uploading}}" class="progress-card">
      <view class="progress-title">{{uploadRetrying ? '网络波动，正在重试' : '上传识别中'}}</view>
      <view class="progress-desc">{{uploadStageText || '正在分析图片内容并提取关注的检查信息，请稍候…'}}</view>
      <view class="progress-number">{{uploadProgress}}%</view>
      <progress percent="{{uploadProgress}}" active active-mode="forwards" stroke-width="6" color="#07c160" />
      <view class="progress-hint">识别通常需要一段时间，请不要离开当前页面。</view>
    </view>

    <view class="bottom-bar" wx:if="{{files.length}}">
      <button class="act primary" bindtap="createDraft" loading="{{uploading}}" disabled="{{uploading}}">
        {{uploading ? (uploadRetrying ? '重试中…' : '识别中…') : '开始识别'}}
      </button>
    </view>
  </block>

  <block wx:elif="{{step === 'edit'}}">
    <view class="select-card summary-card">
      <text class="section-title">确认检查信息</text>
      <view class="summary-hint">请核对识别结果，补全必填信息后再保存。</view>
      <view class="section mini">
        <picker mode="selector" range="{{memberLabels}}" value="{{subjectIndex}}" bindchange="onSubjectPick">
          <view class="picker-row">
            <text class="picker-label">检查成员</text>
            <text class="picker-value">{{memberLabels[subjectIndex] || '请选择检查成员'}} ▾</text>
          </view>
        </picker>
      </view>
      <view class="section mini">
        <text class="section-title required">* 医院</text>
        <input class="input" placeholder="识别不出时请手动填写医院" value="{{hospital}}" bindinput="onHospitalInput" />
      </view>
      <view class="section mini">
        <text class="section-title required">* 报告类型</text>
        <input class="input" placeholder="如：血常规" value="{{reportTypeLabel}}" bindinput="onReportTypeInput" />
      </view>
      <view class="section mini">
        <text class="section-title required">* 报告日期</text>
        <input class="input" placeholder="如：2026-03-20" value="{{reportDate}}" bindinput="onReportDateInput" />
      </view>
      <view class="summary-row"><text class="summary-label">上传时间</text><text class="summary-value">本次上传后自动记录</text></view>
    </view>

    <view class="card result-card">
      <text class="result-title">识别结果（可手动修正后保存）</text>
      <view wx:for="{{metrics}}" wx:key="seq" class="metric-card">
        <input class="m-name" data-idx="{{index}}" data-field="item_name" value="{{item.item_name}}" bindinput="onMetricFieldInput" />
        <view class="metric-grid">
          <input class="m-value" data-idx="{{index}}" data-field="value_text" value="{{item.value_text}}" bindinput="onMetricFieldInput" />
          <input class="m-unit" data-idx="{{index}}" data-field="unit" value="{{item.unit}}" bindinput="onMetricFieldInput" />
          <input class="m-ref" data-idx="{{index}}" data-field="ref_range" value="{{item.ref_range}}" bindinput="onMetricFieldInput" />
        </view>
      </view>
    </view>

    <view wx:if="{{committing}}" class="retry-card">
      <view class="retry-title">{{commitRetrying ? '网络波动，正在重试提交' : '正在提交检查单'}}</view>
      <view class="retry-desc">请保持在当前页面，提交完成后会自动返回历史记录。</view>
    </view>

    <view class="bottom-bar dual-actions">
      <button class="act ghost" bindtap="chooseImage" disabled="{{committing}}">返回重选</button>
      <button class="act primary" bindtap="submitDraft" loading="{{committing}}" disabled="{{committing}}">
        {{committing ? (commitRetrying ? '重试中…' : '提交中…') : '确认并保存'}}
      </button>
    </view>
  </block>
</view>
