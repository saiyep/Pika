.page { padding: 32rpx; }
.preview { margin-bottom: 24rpx; border-radius: 12rpx; overflow: hidden; }
.preview image { width: 100%; }
.btn { margin-bottom: 20rpx; background: #fff; color: #333; }
.btn.primary { background: #07c160; color: #fff; }
.result { margin-top: 32rpx; background: #fff; border-radius: 12rpx; padding: 24rpx; }
.result-title { display: block; font-size: 32rpx; font-weight: 600; margin-bottom: 16rpx; }
.metric { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 26rpx; }
.metric.abnormal .m-value { color: #e64340; font-weight: 600; }
.m-name { flex: 2; color: #333; }
.m-value { flex: 1; text-align: right; color: #333; }
.m-ref { flex: 1.5; text-align: right; color: #999; }
