<view class="page">
  <!-- 只读态 -->
  <view wx:if="{{!editing}}" class="profile" bindtap="startEdit">
    <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar">{{initial}}</view>    <view class="profile-text">
      <text class="name">{{nickname}}</text>
      <text class="role {{isAdmin ? 'admin' : ''}}">{{roleLabel}}</text>
    </view>
    <text class="edit-hint">编辑 ›</text>
  </view>

  <!-- 编辑态 -->
  <view wx:else class="profile-edit">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{pendingAvatar}}" class="avatar-img" src="{{pendingAvatar}}" mode="aspectFill" />
      <image wx:elif="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar">+</view>
    </button>
    <text class="avatar-tip">点击选择微信头像</text>

    <view class="nickname-row">
      <text class="nk-label">昵称</text>
      <input
        class="nk-input"
        type="nickname"
        placeholder="点击填写微信昵称"
        value="{{editNickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="edit-actions">
      <button class="act ghost" bindtap="cancelEdit">取消</button>
      <button class="act primary" bindtap="saveProfile">保存</button>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="goMembers">
      <text class="menu-label">成员管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-label">版本说明</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
