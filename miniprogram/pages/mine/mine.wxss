.page { padding: 32rpx; }
.profile { display: flex; align-items: center; background: #fff; border-radius: 16rpx; padding: 40rpx 32rpx; margin-bottom: 24rpx; }
.avatar { width: 96rpx; height: 96rpx; border-radius: 48rpx; background: #07c160; color: #fff; font-size: 44rpx; display: flex; align-items: center; justify-content: center; margin-right: 24rpx; }
.avatar-img { width: 96rpx; height: 96rpx; border-radius: 48rpx; margin-right: 24rpx; }
.profile-text { display: flex; flex-direction: column; flex: 1; }
.name { font-size: 36rpx; font-weight: 600; color: #222; }
.role { margin-top: 10rpx; font-size: 22rpx; color: #888; background: #f0f0f0; border-radius: 6rpx; padding: 4rpx 16rpx; align-self: flex-start; }
.role.admin { color: #07c160; background: #e7f9ef; }
.edit-hint { font-size: 26rpx; color: #999; }

.login-card { background: #fff; border-radius: 16rpx; padding: 48rpx 32rpx; display: flex; flex-direction: column; align-items: center; margin-bottom: 24rpx; }
.login-title { margin-top: 20rpx; font-size: 34rpx; color: #222; font-weight: 600; }
.login-desc { margin-top: 12rpx; font-size: 24rpx; color: #999; }
.login-btn { margin-top: 32rpx; width: 100%; background: #07c160; color: #fff; border-radius: 12rpx; font-size: 30rpx; }

.edit-card { background: #fff; border-radius: 16rpx; overflow: hidden; }
.edit-row { display: flex; align-items: center; justify-content: space-between; padding: 26rpx 28rpx; border-bottom: 1rpx solid #f2f2f2; }
.edit-row:last-child { border-bottom: none; }
.row-label { font-size: 30rpx; color: #222; }
.avatar-row .avatar-btn { padding: 0; background: transparent; line-height: normal; margin: 0; }
.avatar-row .avatar-btn::after { border: none; }
.avatar-row .avatar,
.avatar-row .avatar-img { margin: 0; width: 96rpx; height: 96rpx; border-radius: 48rpx; }
.nk-input { flex: 1; text-align: right; font-size: 30rpx; color: #333; padding: 0; }
.edit-actions { display: flex; gap: 24rpx; margin: 24rpx 0; }
.act { flex: 1; font-size: 28rpx; border-radius: 10rpx; }
.act.primary { background: #07c160; color: #fff; }
.act.ghost { background: #f2f2f2; color: #666; }

.menu { background: #fff; border-radius: 16rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item:last-child { border-bottom: none; }
.menu-label { font-size: 30rpx; color: #333; }
.menu-label.danger { color: #e64a4a; }
.menu.logout .menu-arrow { color: #e0b0b0; }
.menu-arrow { font-size: 36rpx; color: #ccc; }
